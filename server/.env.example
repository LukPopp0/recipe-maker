# Server Configuration

# PORT: Server port
# Default: 8787
PORT=8787

# NODE_ENV: Runtime environment (development, production, test)
# Default: development
NODE_ENV=development

# RECIPE_DATA_DIR: Directory where recipe JSON files are stored
# Default: ./data/recipes
RECIPE_DATA_DIR=./data/recipes

# DEFAULT_MAIN_IMAGE_URL: Default image URL for recipes without a primary image
# Default: (empty string, no fallback)
DEFAULT_MAIN_IMAGE_URL=

# INGREDIENT_ASSET_DIR: Directory containing the shared ingredient catalog images,
# served at /ingredient-images/*
# Default: ../shared/assets/ingredients
INGREDIENT_ASSET_DIR=../shared/assets/ingredients

# BROWSER_FALLBACK_ENABLED: Use a headless Chromium (Playwright) to render pages whose
# recipe content requires client-side JavaScript, when the static fetch finds neither
# JSON-LD nor enough visible text. Requires a one-time browser download:
#   pnpm --filter server exec playwright install chromium
# Set to "false" or "0" to disable (URL ingestion then relies on static fetch only).
# Default: true
BROWSER_FALLBACK_ENABLED=true

# BROWSER_FETCH_TIMEOUT_MS: Navigation timeout for the headless-browser fallback
# Default: 15000
BROWSER_FETCH_TIMEOUT_MS=15000

# Gemini AI Configuration (Phase 2+)

# GEMINI_API_KEY: Gemini API key for recipe normalization
# Required only when recipe ingestion is enabled (Phase 2+)
# Default: (not set)
GEMINI_API_KEY=

# GEMINI_PRIMARY_MODEL: Primary model for recipe normalization
# Default: gemini-2.5-pro
GEMINI_PRIMARY_MODEL=gemini-2.5-pro

# GEMINI_RETRY_MODEL: Fallback model if primary model fails
# Default: gemini-2.5-flash
GEMINI_RETRY_MODEL=gemini-2.5-flash

# GEMINI_TIMEOUT_MS: Timeout for Gemini API calls in milliseconds.
# Full-recipe extractions routinely take 20-40s; do not set this below 60000.
# Default: 60000
GEMINI_TIMEOUT_MS=60000

# GEMINI_TOKEN_BUDGET: Maximum tokens per request to Gemini
# Default: 8000
GEMINI_TOKEN_BUDGET=8000

# GEMINI_MAX_RETRIES: Maximum retry attempts for Gemini API calls (0-3)
# Default: 1
GEMINI_MAX_RETRIES=1
